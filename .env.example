# Required
APP_ID=                  # Agora App ID (from Agora Console)
APP_CERTIFICATE=         # Agora App Certificate (32-char hex, generates v007 tokens for RTC/RTM + API auth)
LLM_API_KEY=             # LLM provider API key (e.g. OpenAI sk-...)
TTS_VENDOR=rime          # rime | openai | elevenlabs | cartesia
TTS_KEY=                 # TTS provider API key
TTS_VOICE_ID=astra       # Voice ID — depends on vendor (rime: astra, openai: alloy, elevenlabs: voice ID)

# Optional
# LLM_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini
